# LLM verifier service env template
# Start command: bun run llm-verifier-service
# One Railway service = one verifier (e.g. verifier-gpt, verifier-claude).
#
# IMPORTANT
# - Keep template values identical across all verifier services.
# - Use a different VERIFIER_AUTH_TOKEN per verifier service.
# - Worker must use the same token in RUNTIME_NODE_CRE_VERIFY_AUTH_TOKEN.

# Railway provides PORT automatically.
# PORT=9897

# ---------------------------
# Required (all verifier services)
# ---------------------------

# Allowed: openai | xai | anthropic | gemini
# Aliases also supported in code: gpt, grok, claude, google
VERIFIER_PROVIDER=openai
VERIFIER_MODEL=gpt-4.1-mini

# Worker -> verifier bearer auth
VERIFIER_AUTH_TOKEN=

# Shared prompt template identity (must match across all verifier services)
VERIFIER_PROMPT_TEMPLATE_ID=cre-market-verify-template
VERIFIER_PROMPT_TEMPLATE_VERSION=v1
# Optional custom template. If empty, built-in default template is used.
VERIFIER_PROMPT_TEMPLATE=

# Runtime options
VERIFIER_TIMEOUT_MS=20000
VERIFIER_TEMPERATURE=0
VERIFIER_MAX_OUTPUT_TOKENS=700
VERIFIER_STRICT_OUTPUT=true
VERIFIER_REQUIRE_JSON_RESPONSE=true

# ---------------------------
# API keys (set only the one for VERIFIER_PROVIDER)
# ---------------------------
OPENAI_API_KEY=
XAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Optional provider-specific key overrides
VERIFIER_OPENAI_API_KEY=
VERIFIER_XAI_API_KEY=
VERIFIER_ANTHROPIC_API_KEY=
VERIFIER_GEMINI_API_KEY=

# Optional endpoint overrides
VERIFIER_OPENAI_BASE_URL=https://api.openai.com/v1
VERIFIER_XAI_BASE_URL=https://api.x.ai/v1
VERIFIER_ANTHROPIC_MESSAGES_URL=https://api.anthropic.com/v1/messages
VERIFIER_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models

# ---------------------------
# Example A: verifier-gpt (OpenAI)
# ---------------------------
# VERIFIER_PROVIDER=openai
# VERIFIER_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=sk-...
# VERIFIER_AUTH_TOKEN=<token_gpt>
# VERIFIER_PROMPT_TEMPLATE_ID=cre-market-verify-template
# VERIFIER_PROMPT_TEMPLATE_VERSION=v1

# ---------------------------
# Example B: verifier-claude (Anthropic)
# ---------------------------
# VERIFIER_PROVIDER=anthropic
# VERIFIER_MODEL=claude-3-7-sonnet-latest
# ANTHROPIC_API_KEY=sk-ant-...
# VERIFIER_AUTH_TOKEN=<token_claude>
# VERIFIER_PROMPT_TEMPLATE_ID=cre-market-verify-template
# VERIFIER_PROMPT_TEMPLATE_VERSION=v1

# ---------------------------
# Worker mapping example
# ---------------------------
# worker-gpt:
#   RUNTIME_NODE_CRE_VERIFY_URL=https://verifier-gpt-...up.railway.app/verify
#   RUNTIME_NODE_CRE_VERIFY_AUTH_TOKEN=<token_gpt>
#
# worker-claude:
#   RUNTIME_NODE_CRE_VERIFY_URL=https://verifier-claude-...up.railway.app/verify
#   RUNTIME_NODE_CRE_VERIFY_AUTH_TOKEN=<token_claude>
