# Railway node-worker env template
# One Railway service = one worker node.
# Start command: bun run node-worker
#
# Copy this file's values into each node service Variables tab.
# Use 4 services: node-gpt, node-gemini, node-claude, node-grok.

# ---------------------------
# Required (all node services)
# ---------------------------

# Railway provides PORT automatically. Set only for local runs.
# PORT=19001

# Must match orchestrator CHAIN_ID
CHAIN_ID=4801

# Must match orchestrator DON domain config
DON_DOMAIN_NAME=CRE-DON-Consensus
DON_DOMAIN_VERSION=1

# Must match orchestrator contract used for DON typed-data verification.
# Set at least one of these (prefer DON_VERIFIER_CONTRACT).
DON_VERIFIER_CONTRACT=
CONTRACT_ADDRESS=

# Keep round aligned with orchestrator (default 1).
DON_CONSENSUS_ROUND=1

# Worker identity. WORKER_NODE_ID should be the same wallet as WORKER_OPERATOR_ADDRESS.
WORKER_NODE_ID=
WORKER_OPERATOR_ADDRESS=
WORKER_PRIVATE_KEY=

# One of: gpt | gemini | claude | grok
WORKER_MODEL_FAMILY=gpt
WORKER_MODEL_NAME=operator-gpt

# ---------------------------
# Execution mode
# ---------------------------

# deterministic: local mock verdict generation
# cre_confidential_http: call external verifier endpoint
#   - recommended target: `bun run llm-verifier-service`
#   - verifier env template: `orchestrator/.env.example.verifier`
RUNTIME_NODE_EXECUTION_MODE=deterministic

# Required only when RUNTIME_NODE_EXECUTION_MODE=cre_confidential_http
RUNTIME_NODE_CRE_VERIFY_URL=
RUNTIME_NODE_CRE_VERIFY_AUTH_TOKEN=
RUNTIME_NODE_CRE_VERIFY_TIMEOUT_MS=12000

# ---------------------------
# Per-service fill guide
# ---------------------------

# node-gpt
# WORKER_MODEL_FAMILY=gpt
# WORKER_MODEL_NAME=operator-gpt
# WORKER_NODE_ID=0x<gpt_operator_wallet>
# WORKER_OPERATOR_ADDRESS=0x<gpt_operator_wallet>
# WORKER_PRIVATE_KEY=0x<gpt_operator_private_key>

# node-gemini
# WORKER_MODEL_FAMILY=gemini
# WORKER_MODEL_NAME=operator-gemini
# WORKER_NODE_ID=0x<gemini_operator_wallet>
# WORKER_OPERATOR_ADDRESS=0x<gemini_operator_wallet>
# WORKER_PRIVATE_KEY=0x<gemini_operator_private_key>

# node-claude
# WORKER_MODEL_FAMILY=claude
# WORKER_MODEL_NAME=operator-claude
# WORKER_NODE_ID=0x<claude_operator_wallet>
# WORKER_OPERATOR_ADDRESS=0x<claude_operator_wallet>
# WORKER_PRIVATE_KEY=0x<claude_operator_private_key>

# node-grok
# WORKER_MODEL_FAMILY=grok
# WORKER_MODEL_NAME=operator-grok
# WORKER_NODE_ID=0x<grok_operator_wallet>
# WORKER_OPERATOR_ADDRESS=0x<grok_operator_wallet>
# WORKER_PRIVATE_KEY=0x<grok_operator_private_key>
