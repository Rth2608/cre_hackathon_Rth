# verifier-grok (xAI)
# Start command: bun run llm-verifier-service

VERIFIER_PROVIDER=xai
VERIFIER_MODEL=grok-3
VERIFIER_AUTH_TOKEN=

# Keep these identical across all verifier services
VERIFIER_PROMPT_TEMPLATE_ID=cre-market-verify-template
VERIFIER_PROMPT_TEMPLATE_VERSION=v1
VERIFIER_PROMPT_TEMPLATE=

VERIFIER_TIMEOUT_MS=20000
VERIFIER_TEMPERATURE=0
VERIFIER_MAX_OUTPUT_TOKENS=700
VERIFIER_STRICT_OUTPUT=true
VERIFIER_REQUIRE_JSON_RESPONSE=true

# Required
XAI_API_KEY=
VERIFIER_XAI_BASE_URL=https://api.x.ai/v1
