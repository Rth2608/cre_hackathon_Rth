# Full env template
# Single-service mode (recommended): `bun run dev:with-vector`
# Split-service mode:
# - orchestrator: `bun run dev`
# - vector-screening-service: `VECTOR_SCREENING_PORT=$PORT bun run vector-screening-service`

# Core runtime
PORT=8787
SKIP_STARTUP_ENV_VALIDATION=false
REAL_RUNTIME_ONLY=true
REQUIRE_WALLET_AUTH_SIGNATURE=true
WALLET_AUTH_MAX_AGE_MS=300000

# Chain / onchain writer
RPC_URL=
CHAIN_ID=4801
CONTRACT_ADDRESS=
COORDINATOR_PRIVATE_KEY=
TENDERLY_TX_BASE_URL=
ONCHAIN_READ_ENABLED=true
ONCHAIN_READ_STRICT=true
ONCHAIN_LOG_FROM_BLOCK=0
ONCHAIN_MAX_REQUESTS=100
ONCHAIN_SUBMIT_MAX_ATTEMPTS=3
ONCHAIN_SUBMIT_RETRY_DELAY_MS=1200

# DON mode
USE_DON_BUNDLE_FINALIZE=true
USE_DON_SIGNED_REPORTS=true
DON_DISTRIBUTED_MODE=true
DON_DOMAIN_NAME=CRE-DON-Consensus
DON_DOMAIN_VERSION=1
DON_VERIFIER_CONTRACT=
DON_PROMPT_TEMPLATE_HASH=
DON_CONSENSUS_ROUND=1
DON_LEADER_OPERATOR=
DON_OPERATOR_PRIVATE_KEYS_JSON=
DON_ENDPOINT_BUNDLE_SIGNING_ENABLED=true

# Optional CRE CLI runner
CRE_CLI_ENABLED=false
CRE_COMMAND=cre
CRE_ARGS=workflow simulate
CRE_WORKFLOW_PATH=.
CRE_TRIGGER_INDEX=0
CRE_TIMEOUT_MS=30000

# x402
X402_ENABLED=false
X402_PRICE_REQUEST_CREATE=$0.05
X402_PRICE_RUN_VERIFICATION=$0.05
X402_PRICE_NODE_REGISTRATION=$0.01

# World ID
WORLD_ID_APP_ID=
WORLD_ID_ACTION=
WORLD_ID_ALLOWED_PROFILES_JSON=
WORLD_ID_RP_ID=
WORLD_ID_RP_SIGNING_KEY=
WORLD_ID_RP_SIGNATURE_TTL_SECONDS=300
WORLD_ID_VERIFY_API_V4_BASE_URL=https://developer.world.org/api/v4/verify
WORLD_ID_VERIFY_TIMEOUT_MS=8000
WORLD_ID_SESSION_TTL_SECONDS=86400
REQUEST_REQUIRE_WORLD_ID_ON_CREATE=true

# Request queue
REQUEST_AUTO_VERIFY_ENABLED=true
REQUEST_REJECT_CONFLICT_ENABLED=true
REQUEST_SCREENING_HTTP_URL=http://127.0.0.1:9888/screen
REQUEST_SCREENING_HTTP_AUTH_TOKEN=
REQUEST_SCREENING_TIMEOUT_MS=6000
REQUEST_VECTOR_SYNC_ENABLED=true
REQUEST_VECTOR_SYNC_HTTP_URL=http://127.0.0.1:9888/upsert
REQUEST_VECTOR_SYNC_AUTH_TOKEN=
REQUEST_VECTOR_SYNC_TIMEOUT_MS=6000
REQUEST_VECTOR_SYNC_BLOCK_ON_FAILURE=true

# Node registry / endpoint runtime
REQUIRE_REGISTERED_NODES=true
MIN_NODE_STAKE=0
REQUIRE_NODE_ENDPOINT_URL=true
REQUIRE_HEALTHY_NODE_ENDPOINTS=true
NODE_HEARTBEAT_TTL_SECONDS=0
NODE_REFRESH_HEALTH_BEFORE_MATCH=true
NODE_ENDPOINT_HEALTHCHECK_ENABLED=true
NODE_ENDPOINT_HEALTHCHECK_TIMEOUT_MS=2500
NODE_CHALLENGE_TTL_SECONDS=300
NODE_DEFAULT_MODEL_NAME_PREFIX=operator
NODE_ENDPOINT_URL_MAP_JSON=
NODE_ENDPOINT_URL_BY_FAMILY_JSON=
NODE_DEFAULT_ENDPOINT_URL=
NODE_ENDPOINT_VERIFY_ENABLED=true
NODE_ENDPOINT_VERIFY_PATH=/verify
NODE_ENDPOINT_VERIFY_TIMEOUT_MS=8000
NODE_ENDPOINT_REQUIRE_SIGNED_REPORTS=true
NODE_ENDPOINT_BUNDLE_APPROVAL_PATH=/sign-bundle-approval
NODE_ENDPOINT_LEADER_SIGN_PATH=/sign-consensus-bundle
NODE_LIFECYCLE_ONCHAIN_ENABLED=true

# Runtime node execution mode
RUNTIME_NODE_EXECUTION_MODE=deterministic
RUNTIME_NODE_CRE_VERIFY_URL=
RUNTIME_NODE_CRE_VERIFY_URL_MAP_JSON=
RUNTIME_NODE_CRE_VERIFY_AUTH_TOKEN=
RUNTIME_NODE_CRE_VERIFY_AUTH_TOKEN_MAP_JSON=
RUNTIME_NODE_CRE_VERIFY_TIMEOUT_MS=12000

# Optional verifier adapter
CRE_ADAPTER_AUTH_TOKEN=
CRE_ADAPTER_UPSTREAM_URL=
CRE_ADAPTER_UPSTREAM_AUTH_TOKEN=
CRE_ADAPTER_TIMEOUT_MS=15000
CRE_ADAPTER_REQUIRE_SYNC_REPORT=true

# Vector screening service
VECTOR_SCREENING_PORT=9888
VECTOR_SCREENING_AUTH_TOKEN=
VECTOR_SCREENING_STORE_BACKEND=qdrant
VECTOR_SCREENING_STORE_PATH=data/vector-screening-index.json
VECTOR_SCREENING_REQUIRE_INDEXED_VECTORS=true
VECTOR_SCREENING_EMBEDDING_MODE=openai
OPENAI_API_KEY=
VECTOR_SCREENING_OPENAI_API_KEY=
VECTOR_SCREENING_OPENAI_EMBEDDING_URL=https://api.openai.com/v1/embeddings
VECTOR_SCREENING_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_SCREENING_SIMILARITY_THRESHOLD=0.92
VECTOR_SCREENING_DUPLICATE_THRESHOLD=0.985
VECTOR_SCREENING_COMPARE_STATUSES=QUEUED,VERIFYING,APPROVED_PENDING_OPEN,OPEN
VECTOR_SCREENING_UPSERT_TIMEOUT_MS=15000
VECTOR_SCREENING_SCREEN_TIMEOUT_MS=20000
VECTOR_SCREENING_QDRANT_URL=http://qdrant.railway.internal:6333
VECTOR_SCREENING_QDRANT_API_KEY=
VECTOR_SCREENING_QDRANT_COLLECTION=request_screening
VECTOR_SCREENING_QDRANT_VECTOR_SIZE=1536
VECTOR_SCREENING_QDRANT_DISTANCE=Cosine
VECTOR_SCREENING_QDRANT_SEARCH_LIMIT=64

# Optional worker-only vars (if using separate node-worker process)
WORKER_NODE_ID=
WORKER_MODEL_FAMILY=gpt
WORKER_MODEL_NAME=
WORKER_OPERATOR_ADDRESS=
WORKER_PRIVATE_KEY=

# PoR fallback settings
POR_MARKET_ID=1
POR_EPOCH=1
POR_ASSETS_MICROUSDC=1000000000
POR_LIABILITIES_MICROUSDC=950000000
POR_TX_HASH=
POR_ONCHAIN_READ_ENABLED=true
POR_ONCHAIN_READ_STRICT=false
POR_ONCHAIN_AUTO_RECORD_ENABLED=true
POR_ONCHAIN_AUTO_RECORD_STRICT=false
POR_AUTO_DELTA_ASSETS_MICROUSDC=10000000
POR_AUTO_DELTA_LIABILITIES_MICROUSDC=9000000
