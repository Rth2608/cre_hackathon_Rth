# worker-grok env template
# Start command: bun run node-worker

# Must match orchestrator
CHAIN_ID=4801
DON_DOMAIN_NAME=CRE-DON-Consensus
DON_DOMAIN_VERSION=1
DON_VERIFIER_CONTRACT=
CONTRACT_ADDRESS=
DON_CONSENSUS_ROUND=1

# Keep this aligned with orchestrator DON_PROMPT_TEMPLATE_HASH (same hash policy)
DON_PROMPT_TEMPLATE_HASH=

# Worker identity (same wallet)
WORKER_NODE_ID=
WORKER_OPERATOR_ADDRESS=
WORKER_PRIVATE_KEY=

# Model identity
WORKER_MODEL_FAMILY=grok
WORKER_MODEL_NAME=operator-grok

# Verifier mode
RUNTIME_NODE_EXECUTION_MODE=cre_confidential_http
RUNTIME_NODE_CRE_VERIFY_URL=https://<verifier-grok-domain>/verify
RUNTIME_NODE_CRE_VERIFY_AUTH_TOKEN=<same_as_verifier_grok_VERIFIER_AUTH_TOKEN>
RUNTIME_NODE_CRE_VERIFY_TIMEOUT_MS=12000
