# ---------------------------
# Vercel (Production/Preview)
# ---------------------------
# Public HTTPS URL of Railway orchestrator service.
VITE_API_BASE_URL=https://your-orchestrator.up.railway.app

VITE_THIRDWEB_CLIENT_ID=

# World ID Mini App (inside World App)
VITE_WORLD_ID_MINI_APP_ID=
VITE_WORLD_ID_MINI_ACTION=

# Optional external widget path (desktop/browser flow)
VITE_WORLD_ID_EXTERNAL_APP_ID=
VITE_WORLD_ID_EXTERNAL_ACTION=

# Optional legacy compatibility keys.
# Prefer MINI/EXTERNAL keys above for new deployments.
VITE_WORLD_ID_APP_ID=
VITE_WORLD_ID_ACTION=

# Optional Sepolia / Virtual network token display config.
# Chain id default is 11155111 when omitted.
VITE_WORLDCHAIN_SEPOLIA_CHAIN_ID=11155111
# Optional virtual network display name (e.g. Ethereum Sepolia (Virtual)).
VITE_WORLDCHAIN_NETWORK_NAME=Ethereum Sepolia (Virtual)
# Set Tenderly virtual testnet RPC or Ethereum Sepolia RPC.
VITE_WORLDCHAIN_SEPOLIA_RPC_URL=
# Comma-separated ERC20 token addresses to display in wallet snapshot.
VITE_WORLDCHAIN_VIRTUAL_TOKEN_ADDRESSES=

# ---------------------------
# Local dev only (Vite server)
# ---------------------------
# Uncomment for local development and keep VITE_API_BASE_URL unset.
# VITE_API_PROXY_TARGET=http://127.0.0.1:8787
# VITE_ALLOWED_HOSTS=
