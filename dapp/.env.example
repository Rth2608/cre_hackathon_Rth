# ---------------------------
# Vercel (Production/Preview)
# ---------------------------
# Public HTTPS URL of Railway orchestrator service.
VITE_API_BASE_URL=https://your-orchestrator.up.railway.app

VITE_THIRDWEB_CLIENT_ID=
# Set to false only for testing when Mini App wallet cannot sign on requested chain.
# Keep true in production for stronger wallet-auth guarantees.
VITE_REQUIRE_WALLET_AUTH_SIGNATURE=true

# World ID Mini App (inside World App)
VITE_WORLD_ID_MINI_APP_ID=
VITE_WORLD_ID_MINI_ACTION=
# Run Verify 버튼에서 World ID 세션 강제 여부 (backend REQUEST_REQUIRE_WORLD_ID_ON_RUN과 동일하게 맞추기)
VITE_REQUEST_REQUIRE_WORLD_ID_ON_RUN=false
# 자동 FIFO verify 전용 모드일 때 수동 Run Verify 버튼 표시 여부
VITE_REQUEST_MANUAL_RUN_ENABLED=false

# Optional legacy compatibility keys.
# Prefer MINI keys above for new deployments.
VITE_WORLD_ID_APP_ID=
VITE_WORLD_ID_ACTION=

# Optional World Chain Sepolia token display config.
# Chain id default is 4801 when omitted.
VITE_WORLDCHAIN_SEPOLIA_CHAIN_ID=4801
# Optional network display name.
VITE_WORLDCHAIN_NETWORK_NAME=World Chain Sepolia
# Set a World Chain Sepolia RPC.
VITE_WORLDCHAIN_SEPOLIA_RPC_URL=

# ---------------------------
# Local dev only (Vite server)
# ---------------------------
# Uncomment for local development and keep VITE_API_BASE_URL unset.
# VITE_API_PROXY_TARGET=http://127.0.0.1:8787
# VITE_ALLOWED_HOSTS=
